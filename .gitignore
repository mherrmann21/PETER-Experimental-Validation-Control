# Experimental data
data/experiments/**

# Generated calibration and identification artifacts
data/calibration/**
data/identification/**
data/trajectories/**

# results
results/validation/**
results/tracking/**

# Preserve documentation and directory placeholders
!data/**/
!data/**/.gitkeep
!data/**/README.md
!results/**/.gitkeep


### MATLAB ignores
# Autosave files
*.asv
*.m~
*.autosave
*.slx.r*
*.mdl.r*
*.bak

# Derived content-obscured files
*.p

# Compiled MEX files
*.mex*

# Packaged app and toolbox files
*.mlappinstall
*.mltbx

# Deployable archives
*.ctf

# Generated helpsearch folders
helpsearch*/

# Code generation folders
slprj/
sccprj/
codegen/

# Cache files
*.slxc

# Cloud based storage dotfile
.MATLABDriveTag
